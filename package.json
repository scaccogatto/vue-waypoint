{
  "name": "vue-waypoint",
  "version": "5.0.0",
  "license": "MIT",
  "private": false,
  "type": "module",
  "description": "Trigger functions and events based on an element's position on screen — a tiny, dependency-free Vue 3 wrapper around IntersectionObserver.",
  "keywords": [
    "vue",
    "vue3",
    "waypoint",
    "intersection-observer",
    "scroll",
    "viewport",
    "lazy",
    "animation",
    "typescript"
  ],
  "author": "scaccogatto",
  "main": "./dist/vue-waypoint.umd.cjs",
  "module": "./dist/vue-waypoint.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-waypoint.js",
      "require": "./dist/vue-waypoint.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaccogatto/vue-waypoint.git"
  },
  "homepage": "https://github.com/scaccogatto/vue-waypoint#readme",
  "bugs": {
    "url": "https://github.com/scaccogatto/vue-waypoint/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only-lib",
    "build-only-lib": "vite --config vite.config.lib.ts build",
    "build-only": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/",
    "release": "release-it",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^22.18.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.1",
    "release-it": "^20.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.5"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "lint-staged": {
    "*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}": "eslint --fix",
    "*": "prettier --write --ignore-unknown"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
